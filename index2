<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
  <title>PINOCCHIO — AR Menu</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&family=Cinzel:wght@400;600&display=swap" rel="stylesheet" />
  <script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #0e1f1a;
      --bg2:       #122319;
      --surface:   rgba(255,255,255,0.04);
      --gold:      #c9a84c;
      --gold-lt:   #e8c97a;
      --cream:     #f5ede0;
      --text:      #e8ddd0;
      --muted:     rgba(232,221,208,0.45);
      --active:    #c9a84c;
      --ring:      rgba(201,168,76,0.6);
      --crimson:   #b03a2e;
    }

    html, body {
      height: 100%;
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      overflow: hidden;
    }

    /* ─── LAYOUT SHELL ─── */
    .app {
      display: flex;
      flex-direction: column;
      height: 100svh;
      max-width: 430px;
      margin: 0 auto;
      position: relative;
      overflow: hidden;
    }

    /* ─── TOP BAR ─── */
    .top-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 20px 10px;
      position: relative;
      z-index: 10;
    }
    .back-btn {
      width: 42px; height: 42px;
      border-radius: 50%;
      border: 1.5px solid rgba(201,168,76,0.3);
      background: rgba(255,255,255,0.05);
      color: var(--gold);
      font-size: 18px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      backdrop-filter: blur(6px);
    }
    .top-title {
      font-family: 'Cinzel', serif;
      font-size: 15px;
      letter-spacing: 3px;
      color: var(--gold-lt);
    }
    .cart-btn {
      width: 42px; height: 42px;
      border-radius: 50%;
      background: var(--gold);
      color: #0e1f1a;
      font-size: 17px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      position: relative;
    }
    .cart-badge {
      position: absolute; top: -3px; right: -3px;
      width: 17px; height: 17px;
      border-radius: 50%;
      background: var(--crimson);
      color: white;
      font-size: 9px; font-weight: 600;
      display: flex; align-items: center; justify-content: center;
      font-family: 'DM Sans', sans-serif;
    }

    /* ─── MAIN DISH DISPLAY ─── */
    .dish-stage {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      position: relative;
      padding: 0 20px;
    }

    /* Radial glow behind dish */
    .dish-stage::before {
      content: '';
      position: absolute;
      width: 340px; height: 340px;
      border-radius: 50%;
      background: radial-gradient(ellipse, rgba(201,168,76,0.08) 0%, transparent 70%);
      pointer-events: none;
      top: 50%; left: 50%;
      transform: translate(-50%, -52%);
    }

    /* Concentric ring decoration */
    .ring-deco {
      position: absolute;
      border-radius: 50%;
      border: 1px solid rgba(201,168,76,0.08);
      pointer-events: none;
      top: 50%; left: 50%;
    }
    .ring-deco:nth-child(1) { width: 280px; height: 280px; transform: translate(-50%,-52%); }
    .ring-deco:nth-child(2) { width: 340px; height: 340px; transform: translate(-50%,-52%); border-color: rgba(201,168,76,0.04); }
    .ring-deco:nth-child(3) { width: 400px; height: 400px; transform: translate(-50%,-52%); border-color: rgba(201,168,76,0.02); }

    /* Main dish image circle */
    .main-dish-wrap {
      position: relative;
      width: 260px; height: 260px;
      border-radius: 50%;
      overflow: hidden;
      border: 2px solid rgba(201,168,76,0.2);
      box-shadow:
        0 0 60px rgba(0,0,0,0.6),
        0 0 0 8px rgba(201,168,76,0.05),
        0 0 0 16px rgba(201,168,76,0.025);
      cursor: pointer;
      transition: transform 0.3s cubic-bezier(.34,1.56,.64,1);
      flex-shrink: 0;
    }
    .main-dish-wrap:hover { transform: scale(1.03); }
    .main-dish-wrap:active { transform: scale(0.97); }

    .main-dish-img {
      width: 100%; height: 100%;
      object-fit: cover;
      display: block;
      transition: opacity 0.35s ease;
    }
    .main-dish-emoji {
      position: absolute; inset: 0;
      display: flex; align-items: center; justify-content: center;
      font-size: 80px;
    }

    /* AR tap hint */
    .ar-tap-hint {
      position: absolute;
      bottom: -14px; left: 50%;
      transform: translateX(-50%);
      background: var(--gold);
      color: #0e1f1a;
      font-family: 'DM Sans', sans-serif;
      font-size: 9px; font-weight: 600;
      letter-spacing: 2px;
      padding: 4px 14px;
      border-radius: 20px;
      white-space: nowrap;
      text-transform: uppercase;
      box-shadow: 0 4px 14px rgba(201,168,76,0.4);
      animation: float 2s ease-in-out infinite;
    }
    @keyframes float {
      0%,100% { transform: translateX(-50%) translateY(0); }
      50%      { transform: translateX(-50%) translateY(-4px); }
    }

    /* Dish info below image */
    .dish-info {
      margin-top: 28px;
      text-align: center;
      position: relative;
      z-index: 2;
    }
    .dish-info-name {
      font-family: 'Playfair Display', serif;
      font-size: 26px;
      font-weight: 700;
      letter-spacing: 0.02em;
      color: var(--cream);
      margin-bottom: 6px;
      transition: opacity 0.25s;
    }
    .dish-info-desc {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.6;
      max-width: 280px;
      margin: 0 auto 12px;
      transition: opacity 0.25s;
    }
    .dish-info-price {
      font-family: 'Playfair Display', serif;
      font-size: 24px;
      color: var(--gold-lt);
      transition: opacity 0.25s;
    }
    .dish-info-price span {
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      color: var(--muted);
    }
    .dish-info-tags {
      display: flex; gap: 6px; justify-content: center; margin-top: 8px;
    }
    .tag {
      font-size: 10px; padding: 3px 10px;
      border-radius: 20px;
      font-weight: 500; letter-spacing: 0.5px;
    }
    .tag-veg { background: rgba(74,140,65,0.2); color: #7dcc6e; border: 1px solid rgba(74,140,65,0.3); }
    .tag-new { background: rgba(176,58,46,0.2); color: #e07b6f; border: 1px solid rgba(176,58,46,0.3); }

    /* ─── ARROW INDICATOR ─── */
    .caret-row {
      display: flex; justify-content: center;
      padding: 6px 0 2px;
      position: relative; z-index: 2;
    }
    .caret {
      width: 0; height: 0;
      border-left: 8px solid transparent;
      border-right: 8px solid transparent;
      border-top: 10px solid var(--gold);
      filter: drop-shadow(0 2px 4px rgba(201,168,76,0.5));
      opacity: 0;
      transition: opacity 0.3s;
    }
    .caret.visible { opacity: 1; }

    /* ─── THUMBNAIL STRIP ─── */
    .thumb-strip-wrap {
      padding: 8px 0 max(env(safe-area-inset-bottom), 20px);
      background: linear-gradient(0deg, rgba(10,18,15,0.95) 0%, transparent 100%);
      position: relative;
    }
    .thumb-strip {
      display: flex;
      gap: 14px;
      overflow-x: auto;
      padding: 6px 20px 4px;
      scrollbar-width: none;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
    }
    .thumb-strip::-webkit-scrollbar { display: none; }

    .thumb-item {
      flex-shrink: 0;
      scroll-snap-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      cursor: pointer;
      transition: transform 0.25s cubic-bezier(.34,1.56,.64,1);
    }
    .thumb-item:hover { transform: scale(1.08); }
    .thumb-item:active { transform: scale(0.94); }

    .thumb-ring {
      width: 64px; height: 64px;
      border-radius: 50%;
      border: 2px solid rgba(201,168,76,0.2);
      padding: 3px;
      transition: border-color 0.25s, box-shadow 0.25s;
      position: relative;
    }
    .thumb-item.active .thumb-ring {
      border-color: var(--gold);
      box-shadow: 0 0 0 3px rgba(201,168,76,0.15), 0 0 20px rgba(201,168,76,0.3);
    }
    .thumb-ring-inner {
      width: 100%; height: 100%;
      border-radius: 50%;
      overflow: hidden;
      background: rgba(255,255,255,0.05);
      display: flex; align-items: center; justify-content: center;
      font-size: 26px;
    }
    .thumb-ring-inner img {
      width: 100%; height: 100%;
      object-fit: cover; display: block;
    }

    /* Active dot */
    .thumb-item.active .thumb-ring::after {
      content: '';
      position: absolute;
      bottom: -6px; left: 50%;
      transform: translateX(-50%);
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--gold);
      box-shadow: 0 0 8px rgba(201,168,76,0.7);
    }

    .thumb-label {
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 0.5px;
      text-align: center;
      max-width: 64px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      transition: color 0.2s;
    }
    .thumb-item.active .thumb-label {
      color: var(--gold-lt);
      font-weight: 500;
    }

    /* ─── CATEGORY TABS ─── */
    .cat-tabs {
      display: flex;
      gap: 6px;
      padding: 0 20px 10px;
      overflow-x: auto;
      scrollbar-width: none;
    }
    .cat-tabs::-webkit-scrollbar { display: none; }
    .cat-tab {
      flex-shrink: 0;
      padding: 6px 16px;
      border-radius: 20px;
      border: 1px solid rgba(201,168,76,0.2);
      background: transparent;
      color: var(--muted);
      font-family: 'DM Sans', sans-serif;
      font-size: 12px; letter-spacing: 0.5px;
      cursor: pointer;
      transition: all 0.2s;
    }
    .cat-tab.active {
      background: var(--gold);
      color: #0e1f1a;
      border-color: var(--gold);
      font-weight: 600;
    }
    .cat-tab:hover:not(.active) {
      border-color: rgba(201,168,76,0.5);
      color: var(--gold-lt);
    }

    /* ─── LOADING STATE ─── */
    .loading-overlay {
      position: fixed; inset: 0;
      background: var(--bg);
      display: flex; align-items: center; justify-content: center;
      flex-direction: column; gap: 16px;
      z-index: 1000;
      transition: opacity 0.4s;
    }
    .loading-overlay.hidden { opacity: 0; pointer-events: none; }
    .load-ring {
      width: 44px; height: 44px;
      border: 2px solid rgba(201,168,76,0.15);
      border-top-color: var(--gold);
      border-radius: 50%;
      animation: spin 0.9s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .load-text {
      font-family: 'Cinzel', serif;
      font-size: 12px; letter-spacing: 3px;
      color: var(--muted);
    }

    /* ─── AR MODAL ─── */
    .ar-modal {
      display: none;
      position: fixed; inset: 0;
      background: rgba(0,0,0,0.9);
      z-index: 9000;
      align-items: flex-end;
      justify-content: center;
      backdrop-filter: blur(4px);
    }
    .ar-modal.open { display: flex; }
    @media (min-width: 520px) {
      .ar-modal { align-items: center; padding: 20px; }
    }

    .ar-sheet {
      background: #0e1f1a;
      border: 1px solid rgba(201,168,76,0.2);
      border-top: 3px solid var(--gold);
      width: 100%; max-width: 430px;
      max-height: 92svh;
      overflow-y: auto;
      overscroll-behavior: contain;
      animation: slideUp 0.3s cubic-bezier(0.22,1,0.36,1);
    }
    @keyframes slideUp {
      from { transform: translateY(60px); opacity: 0; }
      to   { transform: none; opacity: 1; }
    }

    .ar-sheet-viewer {
      width: 100%; height: 300px;
      background: #060f0d;
      position: relative; overflow: hidden;
    }

    model-viewer {
      display: block;
      width: 100%; height: 300px;
      background: transparent;
      --progress-bar-color: var(--gold);
    }

    .ar-close {
      position: absolute; top: 12px; right: 12px;
      width: 36px; height: 36px;
      border-radius: 50%;
      background: rgba(0,0,0,0.6);
      border: 1px solid rgba(201,168,76,0.2);
      color: var(--cream);
      font-size: 15px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; z-index: 10;
      transition: background 0.15s;
    }
    .ar-close:hover { background: var(--crimson); }

    .ar-sheet-body { padding: 20px 24px 28px; }
    .ar-sheet-name {
      font-family: 'Playfair Display', serif;
      font-size: 22px; font-weight: 700;
      color: var(--cream); margin-bottom: 4px;
    }
    .ar-sheet-desc {
      font-size: 13px; color: var(--muted);
      line-height: 1.7; margin-bottom: 16px;
    }
    .ar-sheet-footer {
      display: flex; align-items: center; justify-content: space-between;
      padding-top: 16px;
      border-top: 1px solid rgba(201,168,76,0.1);
    }
    .ar-sheet-price {
      font-family: 'Playfair Display', serif;
      font-size: 26px; color: var(--gold-lt);
    }
    .ar-sheet-price span { font-family: 'DM Sans'; font-size: 13px; color: var(--muted); }

    .launch-ar-btn {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--gold);
      color: #0e1f1a;
      border: none;
      padding: 12px 24px;
      font-family: 'Cinzel', serif;
      font-size: 12px; font-weight: 600;
      letter-spacing: 2px;
      cursor: pointer;
      border-radius: 2px;
      transition: opacity 0.15s, transform 0.1s;
      min-height: 46px;
    }
    .launch-ar-btn:hover { opacity: 0.9; }
    .launch-ar-btn:active { transform: scale(0.97); }
    .launch-ar-btn:disabled { opacity: 0.5; cursor: not-allowed; }

    /* Placeholder emoji viewer */
    .ar-emoji-viewer {
      position: absolute; inset: 0;
      display: flex; align-items: center; justify-content: center;
      font-size: 90px;
      background: radial-gradient(ellipse, rgba(201,168,76,0.06) 0%, transparent 70%);
    }

    /* Loading spinner on btn */
    .btn-spinner {
      width: 14px; height: 14px;
      border: 2px solid rgba(14,31,26,0.3);
      border-top-color: #0e1f1a;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      display: none;
    }
    .launch-ar-btn.loading .btn-spinner { display: block; }

    /* Transition overlay for dish swap */
    .fade-cover {
      position: absolute; inset: 0;
      background: radial-gradient(circle, rgba(14,31,26,0.95) 0%, transparent 70%);
      opacity: 0; pointer-events: none;
      transition: opacity 0.15s;
      border-radius: 50%;
      z-index: 5;
    }
    .fade-cover.show { opacity: 1; }
  </style>
</head>
<body>

<!-- Loading overlay -->
<div class="loading-overlay" id="loading">
  <div class="load-ring"></div>
  <p class="load-text">LOADING MENU</p>
</div>

<div class="app" id="app" style="display:none">

  <!-- TOP BAR -->
  <div class="top-bar">
    <div class="back-btn">←</div>
    <div class="top-title">PINOCCHIO</div>
    <div class="cart-btn">
      🛒
      <div class="cart-badge" id="cart-count">1</div>
    </div>
  </div>

  <!-- CATEGORY TABS -->
  <div class="cat-tabs" id="cat-tabs"></div>

  <!-- MAIN STAGE -->
  <div class="dish-stage">
    <div class="ring-deco"></div>
    <div class="ring-deco"></div>
    <div class="ring-deco"></div>

    <div class="main-dish-wrap" id="main-dish-wrap" onclick="openARModal()">
      <div class="fade-cover" id="fade-cover"></div>
      <img class="main-dish-img" id="main-img" src="" alt="" />
      <div class="main-dish-emoji" id="main-emoji" style="display:none"></div>
      <div class="ar-tap-hint" id="ar-hint">TAP TO VIEW IN AR</div>
    </div>

    <div class="dish-info">
      <div class="dish-info-name" id="info-name"></div>
      <div class="dish-info-desc" id="info-desc"></div>
      <div class="dish-info-tags" id="info-tags"></div>
      <div class="dish-info-price" id="info-price"></div>
    </div>
  </div>

  <!-- CARET -->
  <div class="caret-row">
    <div class="caret" id="caret"></div>
  </div>

  <!-- THUMBNAIL STRIP -->
  <div class="thumb-strip-wrap">
    <div class="thumb-strip" id="thumb-strip"></div>
  </div>

</div>

<!-- AR MODAL -->
<div class="ar-modal" id="ar-modal">
  <div class="ar-sheet">
    <div class="ar-sheet-viewer" id="ar-viewer-wrap">
      <button class="ar-close" id="ar-close">✕</button>
      <div class="ar-emoji-viewer" id="ar-emoji-fallback"></div>
      <!-- model-viewer injected here -->
    </div>
    <div class="ar-sheet-body">
      <div class="ar-sheet-name" id="modal-name"></div>
      <div class="ar-sheet-desc" id="modal-desc"></div>
      <div class="ar-sheet-footer">
        <div class="ar-sheet-price">
          <span>₹</span><span id="modal-price"></span>
        </div>
        <button class="launch-ar-btn" id="launch-ar-btn" onclick="launchAR()">
          <div class="btn-spinner"></div>
          <span id="launch-btn-text">✦ Place on Table</span>
        </button>
      </div>
    </div>
  </div>
</div>

<script>
/* ─── DATA ─── */
const ASSETS_BASE = '3d-model';

const LOCAL_ASSETS = {
  'pistachio-sauce-bigne-with-ricotta': { folder: 'Pistachio-Sauce-Bigne-with-Ricotta', file: 'Pistachio-Sauce-Bigne-with-Ricotta', scale: 0.25 },
  'pinocchio-tiramisu':                 { folder: 'Pinocchio-Tiramisu',                 file: 'Pinocchio-Tiramisu',                 scale: 0.25 },
  'cheesy-green-lasagne':               { folder: 'Cheesy-Green-Lasagne',               file: 'Cheesy-Green-Lasagne',               scale: 0.12 },
  'fried-calamari':                     { folder: 'Fried-Calamari',                     file: 'Fried-Calamari',                     scale: 0.25 },
};

const EMOJI_MAP = {
  'pistachio-sauce-bigne-with-ricotta': '🍮',
  'pinocchio-tiramisu':                 '🍰',
  'cheesy-green-lasagne':               '🧀',
  'fried-calamari':                     '🦑',
};

const CAT_LABELS = {
  all: 'All', starter: 'Starters', 'main-course': 'Mains', dessert: 'Desserts'
};

const CSV_URL = 'https://docs.google.com/spreadsheets/d/e/2PACX-1vTEkmIGoRgD1rQNmDgmY3lvB7WBOg86iOHHrS0MJ6qQiReuDHsUyX3YV7KoWXxTbefyBUWPTHpvUOt3/pub?output=csv';

const isIOS = /iPhone|iPad|iPod/i.test(navigator.userAgent) ||
              (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1);

/* ─── STATE ─── */
let allDishes = [], rawRows = [];
let activeCategory = 'all';
let activeDishIdx = 0;
let filteredDishes = [];
let mvInstance = null;

/* ─── HELPERS ─── */
function normalizeKey(str) {
  return (str || '').toLowerCase().replace(/\s+/g, '-').trim();
}

function getAssets(dishName) {
  const key = normalizeKey(dishName);
  const e = LOCAL_ASSETS[key];
  if (!e) return { poster: '', glb: '', usdz: '', scale: 0.05 };
  const base = `${ASSETS_BASE}/${e.folder}/${e.file}`;
  return { poster: `${base}.png`, glb: `${base}.glb`, usdz: `${base}.usdz`, scale: e.scale };
}

function parseCSV(text) {
  const lines = text.trim().split('\n');
  if (lines.length < 2) return [];
  const headers = splitLine(lines[0]).map(h => h.trim().toLowerCase());
  return lines.slice(1).map(line => {
    const vals = splitLine(line), obj = {};
    headers.forEach((h, i) => { obj[h] = (vals[i] || '').trim(); });
    return obj;
  });
}

function splitLine(line) {
  const result = []; let cur = '', inQ = false;
  for (let i = 0; i < line.length; i++) {
    const ch = line[i];
    if (ch === '"' && !inQ) { inQ = true; continue; }
    if (ch === '"' && inQ)  { if (line[i+1] === '"') { cur += '"'; i++; } else { inQ = false; } continue; }
    if (ch === ',' && !inQ) { result.push(cur); cur = ''; continue; }
    cur += ch;
  }
  result.push(cur); return result;
}

function truthy(v) { return ['true','yes','1'].includes((v||'').toLowerCase()); }

function rowToDish(row) {
  const assets = getAssets(row['name']);
  return {
    id:        row['id'] || '',
    name:      row['name'] || '',
    category:  (row['category'] || 'other').toLowerCase(),
    desc:      row['description'] || '',
    price:     parseInt(row['price'] || '0', 10),
    veg:       truthy(row['veg']),
    available: truthy(row['available']),
    ...assets,
    emoji:     EMOJI_MAP[normalizeKey(row['name'])] || '🍽️',
  };
}

/* ─── RENDER ─── */
function getCategories() {
  const cats = ['all', ...new Set(allDishes.map(d => d.category))];
  return cats;
}

function renderCatTabs() {
  const wrap = document.getElementById('cat-tabs');
  const cats = getCategories();
  wrap.innerHTML = cats.map(c =>
    `<button class="cat-tab${c === activeCategory ? ' active' : ''}" data-cat="${c}">
      ${CAT_LABELS[c] || (c.charAt(0).toUpperCase() + c.slice(1))}
    </button>`
  ).join('');
  wrap.querySelectorAll('.cat-tab').forEach(btn =>
    btn.addEventListener('click', () => {
      activeCategory = btn.dataset.cat;
      activeDishIdx = 0;
      renderCatTabs();
      renderThumbStrip();
      updateMainDish(0, true);
    })
  );
}

function getFiltered() {
  return activeCategory === 'all' ? allDishes : allDishes.filter(d => d.category === activeCategory);
}

function renderThumbStrip() {
  filteredDishes = getFiltered();
  const strip = document.getElementById('thumb-strip');
  strip.innerHTML = filteredDishes.map((d, i) => {
    const imgOrEmoji = d.poster
      ? `<img src="${d.poster}" alt="${d.name}" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
           style="width:100%;height:100%;object-fit:cover;border-radius:50%;">
         <span style="display:none;font-size:24px;width:100%;height:100%;align-items:center;justify-content:center;border-radius:50%;">${d.emoji}</span>`
      : `<span style="font-size:24px;">${d.emoji}</span>`;

    return `
      <div class="thumb-item${i === activeDishIdx ? ' active' : ''}" data-idx="${i}">
        <div class="thumb-ring">
          <div class="thumb-ring-inner">${imgOrEmoji}</div>
        </div>
        <div class="thumb-label">${d.name.split(' ').slice(0,2).join(' ')}</div>
      </div>`;
  }).join('');

  strip.querySelectorAll('.thumb-item').forEach(item =>
    item.addEventListener('click', () => {
      const idx = parseInt(item.dataset.idx);
      if (idx === activeDishIdx) { openARModal(); return; }
      activeDishIdx = idx;
      updateThumbActive();
      updateMainDish(idx, true);
    })
  );

  // scroll active into view
  const activeEl = strip.querySelector('.thumb-item.active');
  if (activeEl) activeEl.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
}

function updateThumbActive() {
  document.querySelectorAll('.thumb-item').forEach((el, i) => {
    el.classList.toggle('active', i === activeDishIdx);
  });
  const activeEl = document.querySelectorAll('.thumb-item')[activeDishIdx];
  if (activeEl) activeEl.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
}

function updateMainDish(idx, animate = false) {
  filteredDishes = getFiltered();
  const d = filteredDishes[idx];
  if (!d) return;

  const fadeCover = document.getElementById('fade-cover');
  const caret = document.getElementById('caret');

  if (animate) {
    fadeCover.classList.add('show');
    setTimeout(() => {
      setMainDishContent(d);
      fadeCover.classList.remove('show');
    }, 150);
  } else {
    setMainDishContent(d);
  }

  // Show caret on active thumb
  caret.classList.add('visible');

  // Update AR hint visibility
  document.getElementById('ar-hint').textContent = d.glb ? 'TAP TO VIEW IN AR' : 'TAP FOR DETAILS';
}

function setMainDishContent(d) {
  const img = document.getElementById('main-img');
  const emojiEl = document.getElementById('main-emoji');

  if (d.poster) {
    img.src = d.poster;
    img.style.display = 'block';
    emojiEl.style.display = 'none';
    img.onerror = () => {
      img.style.display = 'none';
      emojiEl.textContent = d.emoji;
      emojiEl.style.display = 'flex';
    };
  } else {
    img.style.display = 'none';
    emojiEl.textContent = d.emoji;
    emojiEl.style.display = 'flex';
  }

  document.getElementById('info-name').textContent  = d.name;
  document.getElementById('info-desc').textContent  = d.desc;
  document.getElementById('info-price').innerHTML   =
    `<span style="font-size:14px;font-family:'DM Sans',sans-serif;color:var(--muted)">₹</span>${d.price.toLocaleString('en-IN')}`;

  const tagsEl = document.getElementById('info-tags');
  tagsEl.innerHTML = [
    d.veg ? '<span class="tag tag-veg">🌿 Vegetarian</span>' : '',
  ].join('');
}

/* ─── AR MODAL  ─── */
function openARModal() {
  filteredDishes = getFiltered();
  const d = filteredDishes[activeDishIdx];
  if (!d) return;

  document.getElementById('modal-name').textContent = d.name;
  document.getElementById('modal-desc').textContent = d.desc;
  document.getElementById('modal-price').textContent = d.price.toLocaleString('en-IN');

  const vw = document.getElementById('ar-viewer-wrap');
  // Clear previous model
  const oldMv = vw.querySelector('model-viewer');
  if (oldMv) oldMv.remove();
  mvInstance = null;

  const fallback = document.getElementById('ar-emoji-fallback');

  if (d.poster) {
    fallback.innerHTML = `
      <img src="${d.poster}" alt="${d.name}"
        style="width:100%;height:100%;object-fit:cover;display:block;"
        onerror="this.style.display='none'">`;
  } else {
    fallback.textContent = d.emoji;
  }

  const btn = document.getElementById('launch-ar-btn');
  btn.disabled = false;
  btn.classList.remove('loading');
  document.getElementById('launch-btn-text').textContent = d.glb ? '✦ Place on Table' : '✦ No 3D Model';
  if (!d.glb) btn.disabled = true;

  document.getElementById('ar-modal').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function launchAR() {
  filteredDishes = getFiltered();
  const d = filteredDishes[activeDishIdx];
  if (!d || !d.glb) return;

  const btn = document.getElementById('launch-ar-btn');
  const vw = document.getElementById('ar-viewer-wrap');

  if (mvInstance) {
    mvInstance.activateAR();
    return;
  }

  btn.disabled = true;
  btn.classList.add('loading');
  document.getElementById('launch-btn-text').textContent = 'Loading…';

  const mv = document.createElement('model-viewer');
  mv.setAttribute('src', d.glb);
  if (isIOS && d.usdz) mv.setAttribute('ios-src', d.usdz);

  const s = (d.scale ?? 1).toFixed(6);
  mv.setAttribute('scale', `${s} ${s} ${s}`);
  mv.setAttribute('ar', '');
  mv.setAttribute('ar-modes', 'webxr scene-viewer quick-look');
  mv.setAttribute('ar-placement', 'floor');
  mv.setAttribute('ar-scale', 'fixed');
  mv.setAttribute('camera-controls', '');
  mv.setAttribute('shadow-intensity', '1');
  mv.setAttribute('shadow-softness', '0.8');
  mv.setAttribute('environment-image', 'neutral');
  mv.setAttribute('exposure', '1.1');
  mv.setAttribute('camera-orbit', '0deg 75deg 105%');
  mv.setAttribute('min-camera-orbit', 'auto auto 60%');
  mv.setAttribute('max-camera-orbit', 'auto auto 140%');
  mv.setAttribute('interaction-prompt', 'none');
  mv.setAttribute('loading', 'eager');
  mv.setAttribute('reveal', 'auto');
  mv.setAttribute('touch-action', 'pan-y');
  mv.style.cssText = `
    position:absolute; inset:0;
    width:100%; height:100%;
    background:transparent;
    touch-action:pan-y pinch-zoom;
    z-index:2;
    opacity:0;
    pointer-events:none;
  `;

  vw.appendChild(mv);
  mvInstance = mv;

  mv.addEventListener('load', () => {
    mv.style.opacity = '1';
    mv.style.pointerEvents = 'auto';

    btn.disabled = false;
    btn.classList.remove('loading');
    document.getElementById('launch-btn-text').textContent = '✦ Place on Table';

    // Auto-launch AR
    mv.activateAR();

    mv.addEventListener('ar-status', (e) => {
      if (e.detail.status === 'failed' || e.detail.status === 'not-presenting') {
        btn.disabled = false;
        btn.classList.remove('loading');
        document.getElementById('launch-btn-text').textContent = '✦ Try Again';
      }
    }, { once: true });
  });

  mv.addEventListener('error', () => {
    btn.disabled = false;
    btn.classList.remove('loading');
    document.getElementById('launch-btn-text').textContent = '⚠ Load Failed';
    mv.remove();
    mvInstance = null;
  });
}

function closeARModal() {
  if (mvInstance && typeof mvInstance.pause === 'function') mvInstance.pause();
  const vw = document.getElementById('ar-viewer-wrap');
  const oldMv = vw.querySelector('model-viewer');
  if (oldMv) oldMv.remove();
  mvInstance = null;

  document.getElementById('ar-modal').classList.remove('open');
  document.body.style.overflow = '';
}

document.getElementById('ar-close').addEventListener('click', closeARModal);
document.getElementById('ar-modal').addEventListener('click', e => {
  if (e.target === document.getElementById('ar-modal')) closeARModal();
});
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeARModal(); });

document.addEventListener('visibilitychange', () => {
  if (!mvInstance) return;
  document.hidden
    ? (typeof mvInstance.pause === 'function' && mvInstance.pause())
    : (typeof mvInstance.play  === 'function' && mvInstance.play());
});

/* ─── INIT ─── */
async function init() {
  const loadEl = document.getElementById('loading');
  const appEl  = document.getElementById('app');
  try {
    const res  = await fetch(CSV_URL);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const text = await res.text();
    rawRows    = parseCSV(text);
    allDishes  = rawRows.map(rowToDish).filter(d => d.name && d.available);

    if (!allDishes.length) throw new Error('No dishes');

    loadEl.classList.add('hidden');
    appEl.style.display = 'flex';

    filteredDishes = getFiltered();
    renderCatTabs();
    renderThumbStrip();
    updateMainDish(0, false);

    setTimeout(() => {
      loadEl.style.display = 'none';
    }, 400);

  } catch (err) {
    console.error('Menu error:', err);
    loadEl.innerHTML = `
      <div style="text-align:center;padding:2rem;color:#c9a84c;font-family:'Cinzel',serif;letter-spacing:2px;">
        <div style="font-size:32px;margin-bottom:12px">🍽️</div>
        <div>Could not load menu</div>
        <div style="font-size:11px;opacity:0.5;margin-top:8px;font-family:'DM Sans',sans-serif">Check your connection</div>
      </div>`;
  }
}

init();
</script>
